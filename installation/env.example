# =============================================================================
# goAML-V2 — Environment Variables
# Copy this file to .env on BOTH servers and fill in all values.
# GPU_SERVER_HOST is only needed on the app server.
# =============================================================================

# ── NGC / NIM (GPU server only) ──────────────────────────────────────────────
NGC_API_KEY=

# ── Inter-server routing (app server only) ───────────────────────────────────
# Set to the GPU server's LAN IP or hostname
GPU_SERVER_HOST=192.168.x.x

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=goaml
POSTGRES_PASSWORD=

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=goaml
CLICKHOUSE_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=

# ── MinIO (Milvus backing store) ──────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_URL=http://localhost:5678

# ── Superset ──────────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=
