FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    psycopg2-binary \
    neo4j \
    mcp

COPY mcp_server.py .

EXPOSE 8200

CMD ["uvicorn", "mcp_server:app", "--host", "0.0.0.0", "--port", "8200"]
